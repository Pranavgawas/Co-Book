{
  "manifest_version": 3,
  "name": "SplitSync - Multiplayer Travel",
  "short_name": "SplitSync",
  "version": "1.0.0",
  "description": "Multiplayer travel booking and expense splitting.",
  "permissions": [
    "storage", 
    "activeTab"
  ],
  "host_permissions": [
    "*://*.airbnb.com/*",
    "*://*.airbnb.co.in/*",
    "*://*.makemytrip.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open SplitSync"
  },
  "content_scripts": [
    {
      "js": ["src/content.jsx"],
      "matches": [
        "*://*.airbnb.com/*",
        "*://*.airbnb.co.in/*",
        "*://*.makemytrip.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}

